# ============================================================================
# Polymarket Trading Bot - Environment Configuration
# ============================================================================
# Copy this file to .env and configure with your values
# ============================================================================

# ============================================================================
# REQUIRED SETTINGS
# ============================================================================

# Wallet private key for authentication and transaction signing
# Format: Hexadecimal string without 0x prefix
PRIVATE_KEY=""

# Polymarket CLOB: EOA signs; USDC sits on the proxy shown at https://polymarket.com/settings
# Set FUNDER_ADDRESS to that proxy — required for most MetaMask users (GNOSIS_SAFE is auto-selected).
# USE_POLY_PROXY=false — raw EOA only (rare)
USE_POLY_PROXY=true
# FUNDER_ADDRESS="0xYourProxyFromPolymarketSettings"
# SIGNATURE_TYPE=POLY_GNOSIS_SAFE   # default when FUNDER_ADDRESS is set; or POLY_PROXY (Magic), EOA

# ============================================================================
# NETWORK CONFIGURATION
# ============================================================================

# EVM chain identifier
# 137 = Polygon Mainnet (production)
# 80002 = Polygon Amoy Testnet (testing)
CHAIN_ID=137

# Polymarket CLOB API endpoint base URL
CLOB_API_URL="https://clob.polymarket.com"

# Blockchain RPC endpoint URL (optional)
# If not provided, public RPC endpoints will be used
# RPC_URL="https://polygon-rpc.com"

# RPC authentication token (optional)
# Required if using authenticated RPC endpoints
# RPC_TOKEN=""

# ============================================================================
# DEBUG & LOGGING
# ============================================================================

# Enable verbose debug logging
# Set to "true" for detailed console output
DEBUG="false"

# Log file directory path
# Default: "logs"
LOG_DIR="logs"

# Log file name prefix
# Files will be named: {prefix}-{timestamp}.log
LOG_FILE_PREFIX="bot"

# Optional: Full log file path with date placeholder
# Supports "{date}" placeholder for daily rotation
# Example: "logs/bot-{date}.log"
# LOG_FILE_PATH="logs/bot-{date}.log"

# ============================================================================
# BOT RUNNER SETTINGS
# ============================================================================

# Minimum USDC balance required before bot initialization
# Bot will not start if balance is below this threshold (in USDC)
BOT_MIN_USDC_BALANCE=1

# Wait for next market period boundary before starting
# true = Wait until next 15-minute market boundary
# false = Start immediately (useful for resuming incomplete positions)
WAIT_FOR_NEXT_MARKET_START="false"

# ============================================================================
# MARKET SELECTION
# ============================================================================

# Comma-separated list of markets to monitor and trade
# Valid values: "btc", "eth", "sol", etc.
# Example: "btc,eth" for multiple markets
TRADING_MARKETS="btc"

# ============================================================================
# POLLING CONFIGURATION
# ============================================================================

# Base polling interval in milliseconds
# Lower values increase responsiveness but may increase API rate limit risk
POLL_INTERVAL_MS=200

# Enable adaptive polling frequency adjustment
# Automatically adjusts polling interval based on market activity
ADAPTIVE_POLLING="true"

# Minimum polling interval in milliseconds (adaptive mode)
MIN_POLL_INTERVAL_MS=100

# Maximum polling interval in milliseconds (adaptive mode)
MAX_POLL_INTERVAL_MS=2000

# ============================================================================
# ENTRY PARAMETERS
# ============================================================================

# Initial entry threshold price
# Bot will start buying when price drops below this threshold
ENTRY_THRESHOLD=0.499

# Price reversal detection delta
# Used to detect price reversals and trigger opposite side buys
REVERSAL_DELTA=0.020

# Percentage of reversal delta used in dynamic threshold calculation
# Expressed as decimal (0.5 = 50%)
REVERSAL_DELTA_THRESHOLD_PERCENT=0.5

# Dynamic threshold boost amount
# Additional boost added to dynamic threshold for aggressive opposite side buying
DYNAMIC_THRESHOLD_BOOST=0.04

# ============================================================================
# POSITION SIZING
# ============================================================================

# Number of shares to purchase per side per buy order
SHARES_PER_ORDER=5

# Maximum number of buy attempts allowed per side
MAX_BUYS_PER_SIDE=4

# Order tick size precision
# Valid values: "0.01", "0.001", "0.0001"
ORDER_TICK_SIZE="0.01"

# Maximum sum average price threshold
# Bot will stop buying if sumAvg exceeds this value to maintain profitability
MAX_SUM_AVG=0.98

# ============================================================================
# ORDER EXECUTION SETTINGS
# ============================================================================

# Use Fill-and-Kill (FAK) order type for immediate execution
# FAK orders are filled immediately or cancelled
USE_FAK_ORDERS="true"

# Use Immediate-Or-Cancel (IOC) order type (deprecated)
# Use USE_FAK_ORDERS instead
USE_IOC_ORDERS="false"

# Asynchronous order execution mode
# If true, bot does not wait for order confirmation before proceeding
ASYNC_ORDER_EXECUTION="true"

# Price buffer in cents for order execution
# Additional buffer added to order price for faster fills
PRICE_BUFFER=0.03

# Enable dynamic price buffer adjustment
# Automatically adjusts price buffer based on market volatility
DYNAMIC_PRICE_BUFFER="true"

# Maximum order age before automatic cancellation (milliseconds)
MAX_ORDER_AGE_MS=30000

# ============================================================================
# ORDER CONFIRMATION SETTINGS
# ============================================================================

# Initial delay before checking order status (milliseconds)
ORDER_CHECK_INITIAL_DELAY_MS=100

# Delay between order status check retries (milliseconds)
ORDER_CHECK_RETRY_DELAY_MS=300

# Maximum number of order status check attempts
ORDER_CHECK_MAX_ATTEMPTS=2

# ============================================================================
# HEDGING STRATEGY SETTINGS
# ============================================================================

# Price buffer for immediate second side buy after first side purchase
HEDGE_BUFFER=0.01

# Time threshold for second side buy trigger (milliseconds)
# Second side buy occurs after price remains below threshold for this duration
HEDGE_TIME_THRESHOLD_MS=200

# ============================================================================
# DEPTH-BASED BUY SETTINGS
# ============================================================================

# Depth buy discount percentage threshold
# Triggers immediate buy if price drops this percentage below temporary price
# Expressed as decimal (0.05 = 5% discount)
DEPTH_BUY_DISCOUNT_PERCENT=0.05

# ============================================================================
# RISK MANAGEMENT
# ============================================================================

# Maximum drawdown percentage before automatic stop
# Set to 0 to disable drawdown protection
# Expressed as decimal (0.10 = 10% drawdown)
MAX_DRAWDOWN_PERCENT=0

# Minimum USDC balance threshold before automatic stop
# Bot will stop trading if balance falls below this amount
MIN_BALANCE_USDC=2

# ============================================================================
# NEGATIVE RISK SETTINGS
# ============================================================================

# Enable negative risk order mode for trading bot
NEGATIVE_RISK_MODE="false"

# Global negative risk toggle for allowance scripts
# Keep consistent with NEGATIVE_RISK_MODE
NEG_RISK="false"

# ============================================================================
# STATE MANAGEMENT
# ============================================================================

# State cleanup retention period (days)
# Removes trading state data older than specified number of days
CLEANUP_STATE_DAYS=1

# ============================================================================
# REDEMPTION SCRIPT SETTINGS (OPTIONAL)
# ============================================================================

# Condition ID for manual position redemption
# Used by redemption scripts (src/redeem.ts)
# CONDITION_ID=""

# Index sets for manual position redemption
# Comma-separated list of index sets
# Used by redemption scripts (src/redeem.ts)
# INDEX_SETS="1,2"
